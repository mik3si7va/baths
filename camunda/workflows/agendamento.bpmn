    </sequenceFlow>
    <sequenceFlow id="BP255" name="" sourceRef="BP244" targetRef="BP248" />
    <sequenceFlow id="BP256" name="Sim" sourceRef="BP248" targetRef="BP242">
      <conditionExpression xsi:type="tFormalExpression">${adicionarOutroServico == true}</conditionExpression>
    </sequenceFlow>
    <callActivity id="BP257" name="SUB-PROCESSO 1: PREPARAR SERVIÇOS " calledElement="sub_preparar_servicos">
      <extensionElements>
        <camunda:in source="servicosActualizados" target="servicosActualizados" />
        <camunda:in source="porteAnimal" target="porteAnimal" />
        <camunda:in source="qtdServicos" target="qtdServicos" />
        <camunda:out source="servicosActualizados" target="servicosActualizados" />
        <camunda:out source="servicosOrdenados" target="servicosOrdenados" />
        <camunda:out source="qtdServicos" target="qtdServicos" />
      </extensionElements>
      <incoming>BP258</incoming>
      <outgoing>BP260</outgoing>
    </callActivity>
    <sequenceFlow id="BP258" name="Não" sourceRef="BP248" targetRef="BP257">
      <conditionExpression xsi:type="tFormalExpression">${adicionarOutroServico == false}</conditionExpression>
    </sequenceFlow>
    <callActivity id="BP259"
              name="SUB-PROCESSO 2: GERAR E SELECIONAR OPÇÃO"
              calledElement="sub_gerar_selecionar_opcao">
      <extensionElements>
        <camunda:in source="servicosActualizados" target="servicosActualizados" />
        <camunda:in source="porteAnimal" target="porteAnimal" />
        <camunda:in source="dataPreferida" target="dataPreferida" />
        <camunda:in source="animalId" target="animalId" />
        <camunda:in source="clienteId" target="clienteId" />
        <camunda:in source="funcionarioPreferido" target="funcionarioPreferido" />

        <camunda:out source="solucoes" target="solucoes" />
        <camunda:out source="dataHoraInicio" target="dataHoraInicio" />
        <camunda:out source="dataHoraFim" target="dataHoraFim" />
        <camunda:out source="valorTotal" target="valorTotal" />
        <camunda:out source="funcionarioId" target="funcionarioId" />
        <camunda:out source="salaId" target="salaId" />
        <camunda:out source="opcaoSelecionadaNormalizada" target="opcaoSelecionadaNormalizada" />
        <camunda:out source="operacaoBemSucedida" target="operacaoBemSucedida" />
        <camunda:out source="mensagemErro" target="mensagemErro" />
      </extensionElements>
      <incoming>BP260</incoming>
      <outgoing>BP261</outgoing>
    </callActivity>
    <sequenceFlow id="BP260" name="" sourceRef="BP257" targetRef="BP259" />

    <sequenceFlow id="BP120" name="" sourceRef="BP115" targetRef="BP117" />
    <sequenceFlow id="BP121" name="Não" sourceRef="BP117" targetRef="BP116">
      <conditionExpression xsi:type="tFormalExpression">${clienteRegistado == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="BP122" name="Sim" sourceRef="BP117" targetRef="BP118">
      <conditionExpression xsi:type="tFormalExpression">${clienteRegistado == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="BP123" name="" sourceRef="BP118" targetRef="BP119" />

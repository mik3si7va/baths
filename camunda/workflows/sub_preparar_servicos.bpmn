  <process id="sub_preparar_servicos" name="sub_preparar_servicos" isExecutable="true">
    <extensionElements />
    <userTask id="BP56" name="Funcionário confirma ou altera serviços" implementation="##unspecified" camunda:assignee="funcionario">
      <incoming>BP64</incoming>
      <incoming>BP72</incoming>
      <incoming>BP84</incoming>
      <incoming>BP70</incoming>
      <outgoing>BP65</outgoing>
    </userTask>
    <exclusiveGateway id="BP57" name="Adicionar serviço?">
      <incoming>BP65</incoming>
      <outgoing>BP66</outgoing>
      <outgoing>BP67</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="BP65" name="" sourceRef="BP56" targetRef="BP57" />
    <userTask id="BP58" name="Selecionar serviço a adicionar" implementation="##unspecified" camunda:assignee="funcionario">
      <incoming>BP66</incoming>
      <outgoing>BP68</outgoing>
    </userTask>
    <sequenceFlow id="BP66" name="Sim" sourceRef="BP57" targetRef="BP58">
      <conditionExpression xsi:type="tFormalExpression">${adicionarServico == true}</conditionExpression>
    </sequenceFlow>
    <serviceTask id="BP59" name="Obter preço e duração (topic: obter-preco-duracao)" implementation="##WebService" camunda:type="external" camunda:topic="obter-preco-duracao">
      <incoming>BP68</incoming>
      <outgoing>BP81</outgoing>
    </serviceTask>
    <sequenceFlow id="BP68" name="" sourceRef="BP58" targetRef="BP59" />
    <serviceTask id="BP60" name="Adicionar à lista (topic: adicionar-servico-lista)" implementation="##WebService" camunda:type="external" camunda:topic="adicionar-servico-lista">
      <incoming>BP82</incoming>
      <outgoing>BP70</outgoing>
    </serviceTask>
    <sequenceFlow id="BP70" name="" sourceRef="BP60" targetRef="BP56" />
    <exclusiveGateway id="BP61" name="Lista tem pelo menos um serviço?">
      <incoming>BP67</incoming>
      <outgoing>BP71</outgoing>
      <outgoing>BP74</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="BP67" name="Não" sourceRef="BP57" targetRef="BP61">
      <conditionExpression xsi:type="tFormalExpression">${adicionarServico == false}</conditionExpression>
    </sequenceFlow>
    <startEvent id="BP62" name="Início">
      <outgoing>BP64</outgoing>
    </startEvent>
    <sequenceFlow id="BP64" name="" sourceRef="BP62" targetRef="BP56" />
    <serviceTask id="BP63" name="Informar erro (topic: notificar-erro-sistema)" implementation="##WebService" camunda:type="external" camunda:topic="notificar-erro-sistema">
      <incoming>BP71</incoming>
      <outgoing>BP72</outgoing>
    </serviceTask>
    <sequenceFlow id="BP72" name="" sourceRef="BP63" targetRef="BP56" />
    <sequenceFlow id="BP71" name="Não" sourceRef="BP61" targetRef="BP63">
      <conditionExpression xsi:type="tFormalExpression">${qtdServicos == 0}</conditionExpression>
    </sequenceFlow>
    <serviceTask id="BP73" name="Calcular duração e valor (topic: calcular-resumo-servicos)" implementation="##WebService" camunda:type="external" camunda:topic="calcular-resumo-servicos">
      <incoming>BP74</incoming>
      <outgoing>BP76</outgoing>
    </serviceTask>
    <sequenceFlow id="BP74" name="Sim" sourceRef="BP61" targetRef="BP73">
      <conditionExpression xsi:type="tFormalExpression">${qtdServicos &gt; 0}</conditionExpression>
    </sequenceFlow>
    <businessRuleTask id="BP75" name="Ordenar serviços (Decision: ordenar_servicos)" implementation="##unspecified" camunda:resultVariable="servicosOrdenados" camunda:decisionRef="Decision_09kdji4" camunda:mapDecisionResult="singleEntry">
      <incoming>BP76</incoming>
      <outgoing>BP78</outgoing>
    </businessRuleTask>
    <sequenceFlow id="BP76" name="" sourceRef="BP73" targetRef="BP75" />
    <endEvent id="BP77" name="Fim">
      <incoming>BP78</incoming>
    </endEvent>
    <sequenceFlow id="BP78" name="" sourceRef="BP75" targetRef="BP77" />
    <exclusiveGateway id="BP79" name="Operação bem sucedida?">
      <incoming>BP81</incoming>
      <outgoing>BP82</outgoing>
      <outgoing>BP83</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="BP82" name="Sim" sourceRef="BP79" targetRef="BP60">
      <conditionExpression xsi:type="tFormalExpression">${operacaoBemSucedida == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="BP81" name="" sourceRef="BP59" targetRef="BP79" />
    <serviceTask id="BP80" name="Informar erro (topic: notificar-erro-sistema)" implementation="##WebService" camunda:type="external" camunda:topic="notificar-erro-sistema">
      <incoming>BP83</incoming>
      <outgoing>BP84</outgoing>
    </serviceTask>
    <sequenceFlow id="BP84" name="" sourceRef="BP80" targetRef="BP56" />
    <sequenceFlow id="BP83" name="Não" sourceRef="BP79" targetRef="BP80">
      <conditionExpression xsi:type="tFormalExpression">${operacaoBemSucedida == false}</conditionExpression>
    </sequenceFlow>
  </process>

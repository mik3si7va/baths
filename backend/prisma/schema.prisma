generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id        BigInt   @id @default(autoincrement())
  title     String
  startAt   DateTime @map("start_at") @db.Timestamptz(6)
  endAt     DateTime @map("end_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("events")
}

model TipoServico {
  id                  String               @id @db.Uuid
  tipo                String
  ativo               Boolean              @default(true)
  regrasPreco         RegraPreco[]
  salasServico        SalaServico[]
  funcionarioServicos FuncionarioServico[]

  agendamentoServicos AgendamentoServico[]

  @@map("tipo_servico")
}

model RegraPreco {
  id             String      @id @db.Uuid
  tipoServicoId  String      @map("tipo_servico_id") @db.Uuid
  porteAnimal    PorteEnum   @map("porte_animal")
  precoBase      Decimal     @map("preco_base") @db.Decimal(10, 2)
  duracaoMinutos Int         @map("duracao_minutos")
  tipoServico    TipoServico @relation(fields: [tipoServicoId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_tipo_servico")

  @@map("regra_preco")
}

model Sala {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome         String        @unique
  capacidade   Int
  equipamento  String
  precoHora    Decimal       @map("preco_hora") @db.Decimal(10, 2)
  ativo        Boolean       @default(true)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  salasServico SalaServico[]

  reservasTemporarias  ReservaTemporaria[]
  agendamentoServicos  AgendamentoServico[]

  @@map("sala")
}

model SalaServico {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  salaId         String      @map("sala_id") @db.Uuid
  tipoServicoId  String      @map("tipo_servico_id") @db.Uuid
  dataAssociacao DateTime    @default(now()) @map("data_associacao") @db.Timestamptz(6)
  sala           Sala        @relation(fields: [salaId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_sala")
  tipoServico    TipoServico @relation(fields: [tipoServicoId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_tipo_servico")

  @@unique([salaId, tipoServicoId], map: "unique_sala_servico")
  @@map("sala_servico")
}

model Funcionario {
  id                 String               @id @db.Uuid
  cargo              TipoFuncionarioEnum
  telefone           String
  porteAnimais       PorteEnum[]          @map("porte_animais")
  utilizador         Utilizador           @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_funcionario_utilizador")
  horariosTrabalho   HorarioTrabalho[]
  funcionarioServico FuncionarioServico[]

  reservasTemporarias  ReservaTemporaria[]
  agendamentoServicos  AgendamentoServico[]

  @@map("funcionario")
}

model Cliente {
  id         String     @id @db.Uuid
  telefone   String
  nif        String?    @unique
  morada     String?
  utilizador Utilizador @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cliente_utilizador")
  animais    Animal[]

  @@map("cliente")
}

model Animal {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clienteId      String        @map("cliente_id") @db.Uuid
  nome           String
  especie        String
  raca           String?
  porte          PorteEnum
  dataNascimento DateTime?     @map("data_nascimento") @db.Date
  alergias       String?
  observacoes    String?
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  cliente        Cliente       @relation(fields: [clienteId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_animal_cliente")
  agendamentos   Agendamento[]

  @@map("animal")
}

model Utilizador {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome         String
  email        String          @unique
  passwordHash String?         @map("password_hash")
  estadoConta  EstadoContaEnum @default(PENDENTE_APROVACAO) @map("estado_conta")
  ativo        Boolean         @default(true)
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)
  funcionario  Funcionario?
  cliente     Cliente?

  @@map("utilizador")
}

model HorarioTrabalho {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  funcionarioId String          @map("funcionario_id") @db.Uuid
  diasSemana    DiaSemanaEnum[] @map("dias_semana")
  horaInicio    DateTime        @map("hora_inicio") @db.Time(0)
  horaFim       DateTime        @map("hora_fim") @db.Time(0)
  pausaInicio   DateTime        @default(dbgenerated("'13:00:00'::time")) @map("pausa_inicio") @db.Time(0)
  pausaFim      DateTime        @default(dbgenerated("'14:00:00'::time")) @map("pausa_fim") @db.Time(0)
  ativo         Boolean         @default(true)
  funcionario   Funcionario     @relation(fields: [funcionarioId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_funcionario_horario")

  @@map("horario_trabalho")
}

model FuncionarioServico {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  funcionarioId  String      @map("funcionario_id") @db.Uuid
  tipoServicoId  String      @map("tipo_servico_id") @db.Uuid
  dataAssociacao DateTime    @default(now()) @map("data_associacao") @db.Timestamptz(6)
  funcionario    Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_funcionario")
  tipoServico    TipoServico @relation(fields: [tipoServicoId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_funcionario_tipo_servico")

  @@unique([funcionarioId, tipoServicoId], map: "unique_funcionario_servico")
  @@map("funcionario_servico")
}

model Agendamento {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  animalId            String                @map("animal_id") @db.Uuid
  dataHoraInicio      DateTime              @map("data_hora_inicio") @db.Timestamptz(6)
  dataHoraFim         DateTime              @map("data_hora_fim") @db.Timestamptz(6)
  valorTotal          Decimal               @map("valor_total") @db.Decimal(10, 2)
  estado              EstadoAgendamentoEnum @default(CONFIRMADO)
  checkInRealizadoEm  DateTime?             @map("check_in_realizado_em") @db.Timestamptz(6)
  checkOutRealizadoEm DateTime?             @map("check_out_realizado_em") @db.Timestamptz(6)
  processInstanceId   String?               @map("process_instance_id")
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  animal              Animal                @relation(fields: [animalId], references: [id], onDelete: Restrict, map: "fk_agendamento_animal")
  servicos            AgendamentoServico[]

  metodoPagamento     MetodoPagamentoEnum?  @map("metodo_pagamento")
  pagoEm              DateTime?             @map("pago_em") @db.Timestamptz(6)
  faturaId            String?               @map("fatura_id")

  @@map("agendamento")
}

model AgendamentoServico {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agendamentoId    String      @map("agendamento_id") @db.Uuid
  tipoServicoId    String      @map("tipo_servico_id") @db.Uuid
  funcionarioId    String      @map("funcionario_id") @db.Uuid
  salaId           String      @map("sala_id") @db.Uuid
  dataHoraInicio   DateTime    @map("data_hora_inicio") @db.Timestamptz(6)
  dataHoraFim      DateTime    @map("data_hora_fim") @db.Timestamptz(6)
  precoNoMomento   Decimal     @map("preco_no_momento") @db.Decimal(10, 2)
  duracaoNoMomento Int         @map("duracao_no_momento")
  ordem            Int
  agendamento      Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade, map: "fk_agendamento_servico_agendamento")
  tipoServico      TipoServico @relation(fields: [tipoServicoId], references: [id], onDelete: Restrict, map: "fk_agendamento_servico_tipo")
  funcionario      Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Restrict, map: "fk_agendamento_servico_funcionario")
  sala             Sala        @relation(fields: [salaId], references: [id], onDelete: Restrict, map: "fk_agendamento_servico_sala")

  @@map("agendamento_servico")
}

model ReservaTemporaria {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  salaId            String?      @map("sala_id") @db.Uuid
  funcionarioId     String?      @map("funcionario_id") @db.Uuid
  dataHoraInicio    DateTime     @map("data_hora_inicio") @db.Timestamptz(6)
  dataHoraFim       DateTime     @map("data_hora_fim") @db.Timestamptz(6)
  processInstanceId String       @map("process_instance_id")
  expiresAt         DateTime     @map("expires_at") @db.Timestamptz(6)
  sala              Sala?        @relation(fields: [salaId], references: [id], onDelete: SetNull, map: "fk_reserva_temporaria_sala")
  funcionario       Funcionario? @relation(fields: [funcionarioId], references: [id], onDelete: SetNull, map: "fk_reserva_temporaria_funcionario")

  @@map("reserva_temporaria")
}

enum TipoServicoEnum {
  BANHO
  TOSQUIA_COMPLETA
  TOSQUIA_HIGIENICA
  CORTE_UNHAS
  LIMPEZA_OUVIDOS
  EXPRESSAO_GLANDULAS
  LIMPEZA_DENTES
  APARAR_PELO_CARA
  ANTI_PULGAS
  ANTI_QUEDA
  REMOCAO_NOS

  @@map("tipo_servico_enum")
}

enum PorteEnum {
  EXTRA_PEQUENO
  PEQUENO
  MEDIO
  GRANDE
  EXTRA_GRANDE

  @@map("porte_enum")
}

enum DiaSemanaEnum {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO

  @@map("dia_semana_enum")
}

enum TipoFuncionarioEnum {
  TOSQUIADOR_SENIOR
  TOSQUIADOR
  TOSQUIADOR_ESTAGIARIO
  BANHISTA_SENIOR
  BANHISTA
  BANHISTA_ESTAGIARIO
  RECECIONISTA
  ADMINISTRACAO

  @@map("tipo_funcionario_enum")
}

enum EstadoContaEnum {
  PENDENTE_APROVACAO
  PENDENTE_VERIFICACAO
  ATIVA
  INATIVA
  BLOQUEADA

  @@map("estado_conta_enum")
}

enum EstadoAgendamentoEnum {
  CONFIRMADO
  EM_ATENDIMENTO
  CONCLUIDO
  CANCELADO
  NAO_COMPARECEU

  @@map("estado_agendamento_enum")
}

enum MetodoPagamentoEnum {
  DINHEIRO
  MULTIBANCO
  TRANSFERENCIA

  @@map("metodo_pagamento_enum")
}